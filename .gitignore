# Ignore everything by default
*

# Keep repository metadata
!.gitignore

# Keep essential inputs/code/docs
!README.md
!input.in
!requirements.txt
!environment.yml
!run_qbc.py
!qbc_runtime/
!qbc_runtime/*.py

# Local environments and caches
.venv/
.pycache_local/
__pycache__/
.mplconfig/

# Keep data/model directories (empty)
!models/
models/*
!models/.gitkeep
!models/graph.001.pb
!models/graph.002.pb

!md_pools/
md_pools/*
!md_pools/.gitkeep
!md_pools/TS5_500K/
md_pools/TS5_500K/*
!md_pools/TS5_500K/nve_50.lammpstrj
!md_pools/TS5_500K/nve_51.lammpstrj

# Keep output directories (empty) but ignore generated contents
!qbc_poscars/
qbc_poscars/*
!qbc_poscars/.gitkeep

!qbc_XYZ/
qbc_XYZ/*
!qbc_XYZ/.gitkeep

!qbc_outputs/
qbc_outputs/*
!qbc_outputs/.gitkeep
